# Supabase — public keys (safe to expose in client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — server-only key used by the waitlist API route
# Never commit this. Set it in Cloudflare Pages > Settings > Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Canonical site URL (used for OG metadata)
NEXT_PUBLIC_SITE_URL=https://lolikai.eu
